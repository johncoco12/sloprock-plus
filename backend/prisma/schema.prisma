generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Song {
  filename     String @id
  mtime        Float
  size         Int
  title        String @default("")
  artist       String @default("")
  album        String @default("")
  year         String @default("")
  duration     Float  @default(0)
  tuning       String @default("")
  arrangements Json @default("[]")
  hasLyrics    Boolean @default(false)
  format       String  @default("sloppak") // sloppak | loose
  stemCount    Int     @default(0)
  stemIds      Json    @default("[]")
  tuningName   String  @default("")
  tuningSortKey Int    @default(0)

  @@index([artist])
  @@index([title])
  @@index([tuningName])
  @@index([tuningSortKey])
  @@index([year])
}


model Profile {
  id       Int    @id @default(autoincrement())
  name    String   @unique
  avatarId Int?
  pinCode String
  pinSalt String
  recoveryPhrase String
  recoveryPhraseSalt String
  recoveryPhraseHint String
  locked Boolean @default(false)
  profileSettings Json @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  trackId String @id
  profileId Int 
  createdAt DateTime @default(now())
  modifiedAt DateTime @updatedAt
}

model TrackLoop {
  id        Int      @id @default(autoincrement())
  profileId Int
  trackId   Int
  name      String
  startTime Float
  endTime   Float
  createdAt DateTime @default(now())
  @@index([profileId])
  @@index([trackId])
}

model PermissionGroup {
  id   Int    @id @default(autoincrement())
  name String @unique
  profileIds Int[] // List of profile IDs that belong to this permission group
  permissions String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Track {
  id            Int      @id @default(autoincrement())
  trackId       String   @unique
  createdAt     DateTime @default(now())
  modifiedAt    DateTime @updatedAt
  trackData     TrackData?
  stems         Stems?
  artist        String   @default("")
  title         String   @default("")
  album         String   @default("")
  year          String   @default("")
  duration      Float    @default(0)
  tuning        String   @default("")
  hasLyrics     Boolean  @default(false)
  format        String   @default("sloppak") // sloppak | loose
  tuningName    String   @default("")
  tuningSortKey Int      @default(0)
  @@index([artist])
  @@index([title])
  @@index([tuningName])
  @@index([tuningSortKey])
  @@index([year])
  @@index([trackId])
}

model TrackData {
  id                    Int    @id @default(autoincrement())
  trackId               Int    @unique
  originalFilename      String @unique
  arrangements          Json   @default("[]")
  coverImageStorageId   String?
  audioFileStorageId    String?
  track                 Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model Stems {
  id      Int       @id @default(autoincrement())
  trackId Int       @unique
  track   Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  items   StemData[]
  @@index([trackId])
}

model StemData {
  id                    Int     @id @default(autoincrement())
  stemsId               Int
  stemIndex             Int
  arrangement           String?
  stemAudioFileStorageId String?
  stems                 Stems   @relation(fields: [stemsId], references: [id], onDelete: Cascade)
  @@index([stemsId])
}

model TrackScore {
  id           Int      @id @default(autoincrement())
  profileId    Int
  trackId      String
  bestScore    Int
  playCount    Int      @default(1)
  lastPlayedAt DateTime @default(now())

  @@unique([profileId, trackId])
  @@index([profileId])
  @@index([trackId])
}

model PluginData {
  id        String   @id @default(cuid())
  pluginId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([pluginId, key])
  @@index([pluginId])
}

