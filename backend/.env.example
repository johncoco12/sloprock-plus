# Sloprock Node.js backend — copy to .env and fill in your values

# --- Required ---
# Absolute path to the directory containing your song library files
DLC_DIR=/path/to/your/library

# PostgreSQL connection string (required — SQLite no longer supported)
DATABASE_URL=postgresql://sloprock:sloprock@localhost:5432/sloprock

# --- Optional ---
# Where to store caches and settings.
CONFIG_DIR=

# Path to vgmstream-cli (WEM decoder). Auto-detected if on PATH.
VGMSTREAM_CLI=

# TCP port to listen on
PORT=8080

# Host to bind
HOST=0.0.0.0

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "true" to pretty-print logs (dev only)
LOG_PRETTY=false

# Set to "1" to enable read-only demo mode (blocks POST/DELETE)
SLOPROCK_DEMO_MODE=

# User-managed extra plugins directory (supplements built-in plugins/)
SLOPROCK_PLUGINS_DIR=

# If set, expose GET /api/audio-local-path (Electron integration only)
ELECTRON_MODE=

# Optional: Override the source URL shown in Settings → About
APP_SOURCE_URL=https://github.com/byrongamatos/sloprock

# Optional: Override the license URL (defaults to APP_SOURCE_URL/blob/main/LICENSE)
APP_LICENSE_URL=

# --- MinIO (S3-compatible object storage) ---
# When configured, uploaded files are stored in MinIO instead of the local filesystem.
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=sloprock
# MINIO_USE_SSL=false
